# Backend default generator plugin
# ollama - uses a local open-source LLM through Ollama
# static - returns a deterministic test report without Ollama
# mock - mock generator for tests and demos
# huggingface - optional HuggingFace model plugin
TEXT_GENERATOR=ollama

# Backend default document exporter plugin
# docx - Microsoft Word document
# markdown - Markdown file
DOCUMENT_EXPORTER=docx

# Ollama settings
OLLAMA_BIN=ollama
OLLAMA_MODEL=llama3
OLLAMA_TIMEOUT_SECONDS=300

# Optional HuggingFace settings
HUGGINGFACE_MODEL=t5-small

# Frontend API base URL for Vite
VITE_API_URL=http://127.0.0.1:8000
